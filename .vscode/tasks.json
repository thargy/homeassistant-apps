{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Home Assistant",
      "type": "shell",
      "command": "supervisor_run",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Install App",
      "type": "shell",
      "command": "ha apps install \"local_${input:appName}\"",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Start App",
      "type": "shell",
      "command": "ha apps stop \"local_${input:appName}\"; ha apps start \"local_${input:appName}\"; ha apps logs -f \"local_${input:appName}\"",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "runOptions": {
        "reevaluateOnRerun": false
      }
    },
    {
      "label": "Rebuild and Start App",
      "type": "shell",
      "command": "ha apps rebuild --force \"local_${input:appName}\"; ha apps start \"local_${input:appName}\"; ha apps logs -f \"local_${input:appName}\"",
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Vowels: Build",
      "type": "shell",
      "command": "dotnet build Vowels.slnx",
      "options": {
        "cwd": "${workspaceFolder}/vowels/src"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Vowels: Clean",
      "type": "shell",
      "command": "dotnet clean Vowels.slnx",
      "options": {
        "cwd": "${workspaceFolder}/vowels/src"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Vowels: Rebuild",
      "type": "shell",
      "command": "dotnet build Vowels.slnx --no-incremental",
      "options": {
        "cwd": "${workspaceFolder}/vowels/src"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile",
      "dependsOn": "Vowels: Clean"
    },
    {
      "label": "Vowels: Test",
      "type": "shell",
      "command": "dotnet test Vowels.slnx",
      "options": {
        "cwd": "${workspaceFolder}/vowels/src"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    }
  ],
  "inputs": [
    {
      "id": "appName",
      "type": "pickString",
      "description": "Name of app (to add your app to this list, please edit .vscode/tasks.json)",
      "options": [
        "example",
      ]
    }
  ]
}
